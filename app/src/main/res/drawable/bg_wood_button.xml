<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 바깥 진한 테두리 -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="6dp" />
            <solid android:color="#6E4B2B" />
        </shape>
    </item>

    <!-- 안쪽 버튼 본체 -->
    <item
        android:left="2dp"
        android:top="2dp"
        android:right="2dp"
        android:bottom="2dp">
        <shape
            android:shape="rectangle">

            <corners android:radius="6dp" />

            <solid android:color="#9C6B3C" />

            <stroke
                android:width="1dp"
                android:color="#6E4B2B" />

        </shape>
    </item>




</layer-list>