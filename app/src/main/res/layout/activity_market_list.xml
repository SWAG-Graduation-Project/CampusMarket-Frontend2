<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootFrame"
    android:layout_width="match_parent"

    android:layout_height="match_parent">

    <!-- 1. 배경 이미지 -->
    <ImageView
        android:id="@+id/bgImage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/detailbackgruound"
        android:scaleType="fitXY"

        android:layout_marginBottom="50dp"
        android:contentDescription="@null" />
    <LinearLayout
        android:layout_marginStart="50dp"
        android:layout_marginEnd="50dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">



        <!-- 가운데 영역 -->
        <FrameLayout
android:layout_marginTop="0dp"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_weight="1"
            android:gravity="center">

            <LinearLayout
                android:layout_width="250dp"
                android:layout_height="60dp"
                android:layout_gravity="center"
                android:orientation="horizontal"
                android:gravity="center"

                android:paddingHorizontal="12dp"
                android:background="@drawable/bg_title_board">

                <ImageView
                    android:layout_marginTop="5dp"
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:src="@drawable/logo" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"

                    android:text="덕성 중고 마켓"
                    android:textColor="#D1C1C1"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </FrameLayout>

    </LinearLayout>
    <!-- 2. 실제 화면 UI -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_marginTop="60dp"
        android:layout_height="match_parent"
        android:background="@android:color/transparent"
        tools:context=".StartActivity">

        <!-- 배경 위에 올라갈 UI -->
        <LinearLayout
            android:id="@+id/topUiContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="12dp"
            android:layout_marginStart="45dp"
            android:layout_marginEnd="45dp"
            android:background="@android:color/transparent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- 상단 카테고리 버튼 -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnmarket"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginEnd="8dp"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:text="상점으로 보기"
                        android:textAllCaps="false"
                        android:textColor="#333333"
                        android:textSize="13sp"
                        android:background="@drawable/bg_chip_gray" />

                    <Button
                        android:id="@+id/btnAll"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginEnd="8dp"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:text="전체"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:background="@drawable/bg_chip_selected" />

                    <Button
                        android:id="@+id/btnOuter"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginEnd="8dp"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:text="아우터"
                        android:textAllCaps="false"
                        android:textColor="#666666"
                        android:textSize="13sp"
                        android:background="@drawable/bg_chip_white" />

                    <Button
                        android:id="@+id/btnBag"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginEnd="8dp"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:text="가방"
                        android:textAllCaps="false"
                        android:textColor="#666666"
                        android:textSize="13sp"
                        android:background="@drawable/bg_chip_white" />

                    <Button
                        android:id="@+id/btnTop"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginEnd="8dp"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:text="상의"
                        android:textAllCaps="false"
                        android:textColor="#666666"
                        android:textSize="13sp"
                        android:background="@drawable/bg_chip_white" />

                    <Button
                        android:id="@+id/btnTop2"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginEnd="8dp"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:text="상의"
                        android:textAllCaps="false"
                        android:textColor="#666666"
                        android:textSize="13sp"
                        android:background="@drawable/bg_chip_white" />

                </LinearLayout>
            </HorizontalScrollView>

            <!-- 검색창 줄 -->
            <LinearLayout
                android:layout_marginStart="10dp"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:background="@drawable/bg_search_box">

                    <ImageView
                        android:id="@+id/ivSearch"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_menu_search"
                        android:contentDescription="search" />

                    <EditText
                        android:id="@+id/etSearch"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp"
                        android:background="@null"
                        android:hint="어떤 물건이 필요하신가요?"
                        android:textColor="#222222"
                        android:textColorHint="#666666"
                        android:textSize="14sp"
                        android:singleLine="true"
                        android:padding="0dp" />
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerMarketList"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginStart="50dp"
            android:layout_marginEnd="50dp"
            tools:listitem="@layout/item_market_post"
            android:layout_marginBottom="130dp"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/topUiContainer"
            app:layout_constraintBottom_toTopOf="@id/NavBar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- 1️⃣ NavBar (맨 아래) -->
        <LinearLayout
            android:id="@+id/NavBar"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:orientation="horizontal"
            android:background="#FFFFFF"
            android:weightSum="4"

            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- 홈 -->
            <LinearLayout
                android:id="@+id/gohome"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <ImageView

                    android:layout_width="40dp"
                    android:layout_height="30dp"
                    android:src="@drawable/ichome" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="홈"
                    android:textSize="10sp"
                    android:textColor="#AF6330"
                    android:textStyle="bold"/>
            </LinearLayout>
            <!-- 채팅 -->
            <LinearLayout
                android:id="@+id/goMymarket"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="30dp"
                    android:src="@drawable/icmymarket" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="내 상점"
                    android:textSize="10sp"
                    android:textColor="#999999"
                    android:textStyle="bold"/>
            </LinearLayout>
            <!-- 채팅 -->
            <LinearLayout
                android:id="@+id/gochat"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="30dp"
                    android:src="@drawable/icchat" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="채팅"
                    android:textSize="10sp"
                    android:textColor="#999999"/>
            </LinearLayout>

            <!-- MY -->
            <LinearLayout
                android:id="@+id/gomypage"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="30dp"
                    android:src="@drawable/ic_myinfo" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MY"
                    android:textSize="10sp"
                    android:textColor="#999999"/>
            </LinearLayout>


        </LinearLayout>


    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>