<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".SellDetailActivity">

    <ImageView
        android:id="@+id/ivPopupBg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"
        android:src="@drawable/detailbackgruound" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="10dp"
        android:paddingEnd="20dp"
        android:paddingBottom="70dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:gravity="bottom"
            android:orientation="horizontal">

            <Button
                android:id="@+id/backbutton"
                android:layout_width="50dp"
                android:layout_height="45dp"
                android:background="@android:color/transparent" />

            <TextView
                android:id="@+id/tvStoreTitle"
                android:layout_width="250dp"
                android:layout_height="60dp"
                android:layout_marginStart="10dp"
                android:background="#E6C7A0"
                android:ellipsize="end"
                android:gravity="center"
                android:maxLines="1"
                android:text="상품 등록하기"
                android:textColor="#3A2A1C"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="30dp"
            android:paddingTop="12dp"
            android:paddingEnd="20dp">

            <Button
                android:id="@+id/btnAiRemove"
                android:layout_width="90dp"
                android:layout_height="30dp"
                android:layout_gravity="end"
                android:layout_marginTop="20dp"
                android:layout_marginEnd="10dp"
                android:background="@drawable/bg_black_round_button_small"
                android:text="AI 불러오기"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold" />

            <HorizontalScrollView
                android:id="@+id/photoScroll"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/photoContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" />
            </HorizontalScrollView>

            <ScrollView
                android:id="@+id/formScroll"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="50dp"
                android:fillViewport="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="10dp"
                    android:paddingEnd="20dp">

                    <!-- 카테고리 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="카테고리"
                        android:textColor="#111111"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:scrollbars="none">

                        <LinearLayout
                            android:id="@+id/chipGroupCategory"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <Button
                                android:id="@+id/chipCategoryMain"
                                android:layout_width="wrap_content"
                                android:layout_height="32dp"
                                android:layout_marginEnd="8dp"
                                android:background="@drawable/bg_chip_selected"
                                android:minWidth="0dp"
                                android:paddingStart="16dp"
                                android:paddingEnd="16dp"
                                android:text="가방"
                                android:textAllCaps="false"
                                android:textColor="#3A2A1C"
                                android:textSize="11sp"
                                android:textStyle="bold" />

                            <Button
                                android:id="@+id/chipCategorySub"
                                android:layout_width="wrap_content"
                                android:layout_height="32dp"
                                android:background="@drawable/bg_chip_unselected"
                                android:minWidth="0dp"
                                android:paddingStart="16dp"
                                android:paddingEnd="16dp"
                                android:text="세부 카테고리"
                                android:textAllCaps="false"
                                android:textColor="#3A2A1C"
                                android:textSize="11sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </HorizontalScrollView>

                    <!-- 기존 Spinner 숨김 -->
                    <Spinner
                        android:id="@+id/spMajorCategory"
                        android:layout_width="1dp"
                        android:layout_height="1dp"
                        android:visibility="gone" />

                    <Spinner
                        android:id="@+id/spSubCategory"
                        android:layout_width="1dp"
                        android:layout_height="1dp"
                        android:visibility="gone" />

                    <!-- 상태 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="상태"
                        android:textColor="#111111"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:scrollbars="none">

                        <LinearLayout
                            android:id="@+id/chipGroupCondition"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <Button
                                android:id="@+id/chipCondition"
                                android:layout_width="wrap_content"
                                android:layout_height="32dp"
                                android:background="@drawable/bg_chip_selected"
                                android:minWidth="0dp"
                                android:paddingStart="16dp"
                                android:paddingEnd="16dp"
                                android:text="상태"
                                android:textAllCaps="false"
                                android:textColor="#3A2A1C"
                                android:textSize="11sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </HorizontalScrollView>

                    <Spinner
                        android:id="@+id/spCondition"
                        android:layout_width="1dp"
                        android:layout_height="1dp"
                        android:visibility="gone" />

                    <!-- 색깔 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="색깔"
                        android:textColor="#111111"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:scrollbars="none">

                        <LinearLayout
                            android:id="@+id/chipGroupColor"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <Button
                                android:id="@+id/chipColor"
                                android:layout_width="wrap_content"
                                android:layout_height="32dp"
                                android:background="@drawable/bg_chip_selected_yellow"
                                android:minWidth="0dp"
                                android:paddingStart="16dp"
                                android:paddingEnd="16dp"
                                android:text="노랑"
                                android:textAllCaps="false"
                                android:textColor="#3A2A1C"
                                android:textSize="11sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </HorizontalScrollView>

                    <Spinner
                        android:id="@+id/spColor"
                        android:layout_width="1dp"
                        android:layout_height="1dp"
                        android:visibility="gone" />

                    <!-- 제목 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="제목"
                        android:textColor="#111111"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/etTitle"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_edittext_box"
                        android:hint="제목을 입력해주세요"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:textColor="#111111"
                        android:textColorHint="#9A9A9A"
                        android:textSize="12sp" />

                    <!-- 가격 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="가격"
                        android:textColor="#111111"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/btnPriceDirect"
                            android:layout_width="50dp"
                            android:layout_height="26dp"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/bg_price_black"
                            android:text="판매"
                            android:textAllCaps="false"
                            android:textColor="#FFFFFF"
                            android:textSize="10sp" />

                        <Button
                            android:id="@+id/btnPriceShare"
                            android:layout_width="50dp"
                            android:layout_height="26dp"
                            android:background="@drawable/bg_price_gray"
                            android:text="나눔"
                            android:textAllCaps="false"
                            android:textColor="#FFFFFF"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <EditText
                        android:id="@+id/etPrice"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_edittext_box"
                        android:hint="가격을 입력해주세요"
                        android:inputType="number"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:textColor="#111111"
                        android:textColorHint="#9A9A9A"
                        android:textSize="12sp" />

                    <!-- 상품 설명 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="상품 설명"
                        android:textColor="#111111"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/etDescription"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_edittext_box"
                        android:gravity="top|start"
                        android:hint="상품 설명을 입력해주세요"
                        android:inputType="textMultiLine"
                        android:padding="10dp"
                        android:textColor="#111111"
                        android:textColorHint="#555555"
                        android:textSize="11sp" />
                </LinearLayout>
            </ScrollView>

            <Button
                android:id="@+id/btnSell"
                android:layout_width="170dp"
                android:layout_height="38dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="10dp"
                android:background="@drawable/bg_gray_round_button"
                android:text="판매하기"
                android:textAllCaps="false"
                android:textColor="#111111"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/NavBar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_gravity="bottom"
        android:background="#FFFFFF"
        android:orientation="horizontal"
        android:weightSum="4">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="30dp"
                android:src="@drawable/ichome" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="홈"
                android:textColor="#AF6330"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="30dp"
                android:src="@drawable/icmymarket" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="내 상점"
                android:textColor="#999999"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="30dp"
                android:src="@drawable/icchat" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="채팅"
                android:textColor="#999999"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="30dp"
                android:src="@drawable/ic_myinfo" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MY"
                android:textColor="#999999"
                android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>

</FrameLayout>