<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="300dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_market_popup">

    <!-- 상단 나무 헤더 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:gravity="center"
        android:text="상품 상세보기"
        android:textColor="#FFF4D6"
        android:textSize="16sp"
        android:textStyle="bold"
        android:background="@drawable/bg_popup_header" />

    <!-- 본문 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- 상품 이미지 -->
        <ImageView
            android:id="@+id/ivProduct"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:background="@drawable/bg_popup_image"
            android:scaleType="centerCrop" />

        <!-- 제목 -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="상품 이름 상품 이름 상품 이름"
            android:textColor="#111111"
            android:textSize="16sp"
            android:textStyle="bold"
            android:maxLines="2"
            android:ellipsize="end" />

        <!-- 가격 -->
        <TextView
            android:id="@+id/tvPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="15,000원"
            android:textColor="#8B4B1F"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- 구분선 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginTop="10dp"
            android:background="#EAD7C4" />

        <!-- 태그 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="가방"
                android:background="@drawable/bg_tag_gray"
                android:padding="6dp"
                android:textSize="12sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="양호"
                android:background="@drawable/bg_tag_green"
                android:padding="6dp"
                android:textSize="12sp"
                android:layout_marginStart="6dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="갈색"
                android:background="@drawable/bg_tag_brown"
                android:padding="6dp"
                android:textSize="12sp"
                android:layout_marginStart="6dp"/>
        </LinearLayout>

        <!-- 설명 -->
        <TextView
            android:id="@+id/tvDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="탈취 청소와 전자기기 관리에 최적화된 초미세 면봉입니다..."
            android:textColor="#444444"
            android:textSize="12sp"
            android:lineSpacingExtra="2dp"/>
    </LinearLayout>

    <!-- 하단 버튼 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnLocker"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="채팅하기"
            android:textColor="#FFF4D6"
           />

        <Button
            android:id="@+id/btnLike"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="관심 24"
            android:textColor="#FFF4D6"
            android:background="@drawable/bg_popup_bottom_right"/>
    </LinearLayout>

</LinearLayout>