<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="280dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_white_round_dialog"
    android:padding="20dp">

    <!-- 제목 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="해당 글을 신고하시겠습니까?"
        android:textColor="#222222"
        android:textSize="15sp"
        android:textStyle="bold"
        android:gravity="center" />

    <!-- 항목들 -->
    <TextView
        android:id="@+id/option1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14dp"
        android:text="선입금 요구"
        android:gravity="center"
        android:textSize="13sp" />

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0"/>

    <TextView
        android:id="@+id/option2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14dp"
        android:text="외부 메신저 유도"
        android:gravity="center"
        android:textSize="13sp" />

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0"/>

    <TextView
        android:id="@+id/option3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14dp"
        android:text="욕설 / 비하"
        android:gravity="center"
        android:textSize="13sp" />

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0"/>

    <TextView
        android:id="@+id/option4"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14dp"
        android:text="기타 (직접 작성)"
        android:gravity="center"
        android:textSize="13sp" />

    <!-- 안내 문구 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="허위 신고일 경우 제재를 받을 수 있어요"
        android:textColor="#FF6B6B"
        android:textSize="11sp"
        android:gravity="center"
        android:layout_marginTop="10dp" />

    <!-- 버튼 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:orientation="horizontal"
        android:gravity="center">

        <Button
            android:id="@+id/btnBack"
            android:layout_width="100dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_gray_round_button"
            android:text="돌아가기"
            android:textColor="#222222"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/btnSubmitReport"
            android:layout_width="100dp"
            android:layout_height="40dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/bg_brown_circle"
            android:text="신고하기"
            android:textColor="#FFFFFF"
            android:textAllCaps="false" />
    </LinearLayout>

</LinearLayout>